{% extends "base.html.j2" %}

{% block title %}Pipeline Failed: {{ pipeline_name }}{% endblock %}

{% block header %}
        <div class="header header-failure">
            <span class="badge badge-failure">FAILED</span>
            <h1>{{ pipeline_name }}</h1>
        </div>
{% endblock %}

{% block body_content %}
        <p>Pipeline failed at <strong>{{ failed_at }}</strong>.</p>

        <div class="stats-row">
            <div class="stat">
                <div class="stat-value stat-value-success">{{ assets_succeeded | default(0) }}</div>
                <div class="stat-label">Succeeded</div>
            </div>
            <div class="stat">
                <div class="stat-value stat-value-failure">{{ assets_failed | default(1) }}</div>
                <div class="stat-label">Failed</div>
            </div>
            <div class="stat">
                <div class="stat-value">{{ duration | default('N/A') }}</div>
                <div class="stat-label">Duration</div>
            </div>
        </div>

        {% if failed_asset %}
        <div class="warning-block">
            <div class="mono">{{ failed_asset }}</div>
            {% if failed_step %}
            <div class="text-muted">Step: {{ failed_step }}</div>
            {% endif %}
        </div>
        {% endif %}

        <div class="error-section">
            <h2>Error Message</h2>
            <pre class="error-message">{{ error_message | default('Unknown error') }}</pre>
        </div>

        {% if internal and stacktrace %}
        <details>
            <summary>Stack Trace</summary>
            <pre class="stacktrace">{{ stacktrace }}</pre>
        </details>
        {% endif %}

        {% if internal and tags %}
        <div class="tags">
            <strong>Run tags:</strong>
            {% for key, value in tags.items() %}
            <span class="tag">{{ key }}: {{ value }}</span>
            {% endfor %}
        </div>
        {% endif %}

        {% if internal %}
        <div>
            {% if dagster_url %}
            <a href="{{ dagster_url }}" class="btn">View in Dagster</a>
            {% endif %}
            {% if logs_url %}
            <a href="{{ logs_url }}" class="btn">View Logs</a>
            {% endif %}
        </div>
        {% endif %}
{% endblock %}

{% block footer_internal %}
            <p>Run ID: {{ run_id | default('N/A') }}</p>
{% endblock %}

{% block footer_after_env %}
            {% if retry_count %}
            <p>Retry Attempt: {{ retry_count }}</p>
            {% endif %}
{% endblock %}
