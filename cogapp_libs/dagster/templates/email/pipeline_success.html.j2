{% extends "base.html.j2" %}

{% block title %}Pipeline Success: {{ pipeline_name }}{% endblock %}

{% block extra_css %}
        .header {
            border-bottom: 3px solid {{ c.success }};
            padding-bottom: 16px;
            margin-bottom: 20px;
        }
        .success-badge {
            background-color: {{ c.success }};
            color: {{ c.white }};
            padding: 4px 12px;
            border-radius: 16px;
            font-size: 14px;
            font-weight: 500;
            display: inline-block;
        }
        .btn { margin-top: 16px; }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            margin: 20px 0;
        }
        .stat-card {
            background-color: {{ c.cream }};
            border-radius: 6px;
            padding: 16px;
            text-align: center;
        }
        .stat-value {
            font-size: 28px;
            font-weight: 600;
            color: {{ c.slate }};
        }
        .stat-label {
            font-size: 13px;
            color: {{ c.grey }};
            margin-top: 4px;
        }
        .assets-section {
            margin: 24px 0;
        }
        .assets-section h2 {
            font-size: 16px;
            margin-bottom: 12px;
            color: {{ c.slate }};
        }
        .asset-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .asset-table {
            width: 100%;
            border-collapse: collapse;
        }
        .asset-table td {
            padding: 8px 0;
            border-bottom: 1px solid {{ c.cream }};
            font-size: 13px;
        }
        .asset-name {
            font-family: monospace;
        }
        .asset-records {
            color: {{ c.grey }};
            text-align: right;
            white-space: nowrap;
        }
        @media only screen and (max-width: 480px) {
            .stats-grid { grid-template-columns: 1fr; gap: 10px; }
            .stat-value { font-size: 22px; }
            .asset-item { flex-direction: column; gap: 2px; }
        }
{% endblock %}

{% block header %}
        <div class="header">
            <span class="success-badge">SUCCESS</span>
            <h1>{{ pipeline_name }}</h1>
        </div>
{% endblock %}

{% block body_content %}
        <p>Pipeline completed successfully at <strong>{{ completed_at }}</strong>.</p>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value">{{ assets_materialized }}</div>
                <div class="stat-label">Assets Materialized</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">{{ duration }}</div>
                <div class="stat-label">Duration</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">{{ total_records | default('N/A') }}</div>
                <div class="stat-label">Total Records</div>
            </div>
            {% if checks_passed is not none %}
            <div class="stat-card">
                {% if checks_total %}
                <div class="stat-value">{{ checks_passed }}/{{ checks_total }}</div>
                {% else %}
                <div class="stat-value">{{ checks_passed }}</div>
                {% endif %}
                <div class="stat-label">Checks Passed</div>
            </div>
            {% endif %}
        </div>

        {% if assets %}
        <div class="assets-section">
            <h2>Materialized Assets</h2>
            <table class="asset-table">
                {% for asset in assets %}
                <tr>
                    <td class="asset-name">{{ asset.name }}</td>
                    <td class="asset-records">{% if asset.records is not none %}{{ asset.records }} records{% else %}--{% endif %}</td>
                </tr>
                {% endfor %}
            </table>
        </div>
        {% endif %}

        {% if internal and dagster_url %}
        <a href="{{ dagster_url }}" class="btn" style="color: {{ c.white }} !important;">View in Dagster</a>
        {% endif %}
{% endblock %}

{% block footer_internal %}
            <p>Run ID: {{ run_id | default('N/A') }}</p>
{% endblock %}
